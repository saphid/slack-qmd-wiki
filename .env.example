# Slack OAuth token. Prefer a user token if you want "channels I can access".
# Required scopes are documented in README.md.
# Keep real values in .env; .env is gitignored.
SLACK_USER_TOKEN=

# Or, for bot-limited syncs:
# SLACK_BOT_TOKEN=

# Optional: independent refresh grant for unattended user-token syncs.
# SLACK_REFRESH_TOKEN=
# SLACK_OAUTH_CLIENT_ID=
# SLACK_TOKEN_EXPIRES_AT=
